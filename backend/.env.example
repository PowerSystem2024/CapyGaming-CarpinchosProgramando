# .env.example
# Configuración de Base de Datos
DB_USER=postgres
DB_HOST=localhost
DB_NAME=capygaming
DB_PASSWORD=1234
DB_PORT=5432

# Configuración de Autenticación JWT
JWT_SECRET=tu_clave_secreta_super_segura_minimo_32_caracteres_aqui

# Configuración del Servidor
PORT=3001

# MercadoPago
# Para obtener tu Access Token y Public Key:
# 1. Crea una cuenta en https://www.mercadopago.com.ar/developers
# 2. Crea una aplicación
# 3. Para TEST: Usa credenciales de prueba (TEST-...)
# 4. Para PRODUCCIÓN: Usa credenciales reales (APP_USR-...)
MERCADOPAGO_ACCESS_TOKEN=YOUR-ACCESS-TOKEN-HERE
MERCADOPAGO_PUBLIC_KEY=YOUR-PUBLIC-KEY-HERE

# URLs de la aplicación
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001